# ── LLM Provider ──────────────────────────────────
# Works with any OpenAI-compatible API.
#
# OpenAI
#   LLM_API_KEY=sk-openai-key
#   LLM_MODEL=gpt-4o
#   LLM_ENDPOINT=https://api.openai.com/v1
#
# DeepSeek (OpenAI-compatible, no image gen)
#   LLM_API_KEY=sk-deepseek-key
#   LLM_MODEL=deepseek-chat
#   LLM_ENDPOINT=https://api.deepseek.com/v1
#
# Anthropic (via proxy) or any OpenAI-compatible endpoint

LLM_API_KEY=
LLM_MODEL=gpt-4o
LLM_ENDPOINT=https://api.openai.com/v1

# ── Image Generation ─────────────────────────────
# Uses DALL-E 3 via OpenAI. When using a non-OpenAI provider,
# set IMAGE_GEN_ENABLED=false to use the built-in SVG fallback
# (which already shows post content, hook, and branding).

IMAGE_GEN_ENABLED=false
IMAGE_MODEL=dall-e-3
IMAGE_SIZE=1024x1024

# ── Content Preferences ──────────────────────────
POST_TONE="professional but conversational, occasional humour"
POST_LENGTH="400-600 words"
POSTS_PER_DAY=1
